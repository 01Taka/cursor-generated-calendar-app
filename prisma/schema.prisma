generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  timezone      String    @default("UTC")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  intentTypes         IntentType[]
  timeBlocks          TimeBlock[]
  weeklyIntentBudgets WeeklyIntentBudget[]
  dayReflections      DayReflection[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model IntentType {
  id        String    @id @default(cuid())
  userId    String
  name      String
  colorHex  String
  sortOrder Int       @default(0)
  isDefault Boolean   @default(false)
  archivedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks  TimeBlock[]
  budgets WeeklyIntentBudget[]

  @@unique([userId, name])
}

model TimeBlock {
  id                   String   @id @default(cuid())
  userId               String
  intentTypeId         String
  title                String
  startAt              DateTime
  endAt                DateTime
  isDraft              Boolean  @default(false)
  carryForwardSourceId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  intentType         IntentType                @relation(fields: [intentTypeId], references: [id])
  carryForwardSource TimeBlock?                @relation("CarryForward", fields: [carryForwardSourceId], references: [id])
  carriedCopies      TimeBlock[]               @relation("CarryForward")
  carrySelections    DayReflectionCarryBlock[]

  @@index([userId, startAt, endAt])
}

model WeeklyIntentBudget {
  id           String   @id @default(cuid())
  userId       String
  intentTypeId String
  weekStart    DateTime @db.Date
  targetHours  Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  intentType IntentType @relation(fields: [intentTypeId], references: [id])

  @@unique([userId, intentTypeId, weekStart])
}

model DayReflection {
  id           String   @id @default(cuid())
  userId       String
  reflectDate  DateTime @db.Date
  note         String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  carryBlocks  DayReflectionCarryBlock[]

  @@unique([userId, reflectDate])
}

model DayReflectionCarryBlock {
  reflectionId String
  timeBlockId  String

  reflection DayReflection @relation(fields: [reflectionId], references: [id], onDelete: Cascade)
  timeBlock  TimeBlock     @relation(fields: [timeBlockId], references: [id], onDelete: Cascade)

  @@id([reflectionId, timeBlockId])
}
